@{
    ViewBag.Title = "Citizen Services";
}

<div class="container" style="margin-top: 40px; padding-bottom: 80px;">
    <h2 style="font-weight: 900; color: #0038a8; text-transform: uppercase;">Citizen Services Directory</h2>
    <hr style="border-top: 3px solid #f9a602; width: 50px; margin-left: 0;" />

    <div class="row">
        <div class="col-md-8">
            <p style="margin-bottom: 30px; font-size: 1.1em; color: #666;">Access various city department forms and online applications below.</p>
            <div class="row">
                <div class="col-sm-6" style="margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; padding: 20px; background: white; border: 1px solid #eee; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.03);">
                        <i class="glyphicon glyphicon-leaf" style="font-size: 25px; color: #0038a8; margin-right: 15px;"></i>
                        <div><h5 style="margin:0; font-weight:bold;">ENRO Permits</h5><small class="text-muted">Environment & Natural Resources</small></div>
                    </div>
                </div>
                <div class="col-sm-6" style="margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; padding: 20px; background: white; border: 1px solid #eee; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.03);">
                        <i class="glyphicon glyphicon-heart" style="font-size: 25px; color: #0038a8; margin-right: 15px;"></i>
                        <div><h5 style="margin:0; font-weight:bold;">Health Card</h5><small class="text-muted">Yellow Card Application</small></div>
                    </div>
                </div>
                <div class="col-sm-6" style="margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; padding: 20px; background: white; border: 1px solid #eee; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.03);">
                        <i class="glyphicon glyphicon-education" style="font-size: 25px; color: #0038a8; margin-right: 15px;"></i>
                        <div><h5 style="margin:0; font-weight:bold;">Scholarships</h5><small class="text-muted">Tertiary Education Subsidy</small></div>
                    </div>
                </div>
                <div class="col-sm-6" style="margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; padding: 20px; background: white; border: 1px solid #eee; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.03);">
                        <i class="glyphicon glyphicon-map-marker" style="font-size: 25px; color: #0038a8; margin-right: 15px;"></i>
                        <div><h5 style="margin:0; font-weight:bold;">Zoning Map</h5><small class="text-muted">Land Use & Urban Planning</small></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div style="background: #0038a8; color:white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,56,168,0.2);">
                <h5 style="font-weight: bold; margin-top: 0; color: #f9a602;">24/7 EMERGENCY HOTLINE</h5>
                <h2 style="margin: 15px 0; font-weight: 900; font-size: 2.2em;">(02) 8-LUMINA</h2>
                <p style="font-size: 0.9em; opacity: 0.9; line-height: 1.4;">For immediate police assistance, medical emergencies, or fire rescue, our central dispatch is ready to help.</p>
                <hr style="border-top: 1px solid rgba(255,255,255,0.1);" />
                <p class="small text-warning"><strong>Non-Emergency:</strong> (02) 8-123-4567</p>
            </div>
        </div>
    </div>
</div>